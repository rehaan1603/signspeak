{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "1. Install dependencies",
      "type": "shell",
      "command": "pip install -r requirements.txt",
      "problemMatcher": []
    },
    {
      "label": "2. Start SignSpeak server",
      "type": "shell",
      "command": "python -m uvicorn backend.app:app --reload --port 8000",
      "options": { "env": { "PYTHONPATH": "src" } },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Retrain model (synthetic data)",
      "type": "shell",
      "command": "python src/generate_synthetic_data.py && python src/train.py",
      "problemMatcher": []
    }
  ]
}
